{
  "name": "turnkeyai",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @turnkeyai/browser-relay-peer && npm run build --workspace @turnkeyai/control-center && npm run build --workspace @turnkeyai/cli",
    "build:control-center": "npm run build --workspace @turnkeyai/control-center",
    "build:relay-extension": "npm run build --workspace @turnkeyai/browser-relay-peer",
    "verify:relay-extension": "tsx packages/browser-relay-peer/scripts/verify-extension-dist.ts",
    "relay:install-smoke": "tsx scripts/relay-extension-install-smoke.ts",
    "cdp:launch": "tsx scripts/launch-cdp-chrome.ts",
    "cdp:wait": "tsx scripts/wait-for-cdp-endpoint.ts",
    "cdp:smoke": "tsx scripts/direct-cdp-smoke.ts",
    "relay:launch": "tsx scripts/launch-relay-chrome.ts",
    "relay:wait": "tsx scripts/wait-for-relay-peer.ts",
    "relay:smoke": "tsx scripts/relay-smoke.ts",
    "transport:soak": "tsx scripts/browser-transport-soak.ts",
    "tooluse:e2e": "tsx scripts/tool-use-e2e.ts",
    "tooluse:e2e:real-matrix": "tsx scripts/tool-use-e2e.ts --real-llm-matrix",
    "mission:e2e": "tsx scripts/mission-tool-use-e2e.ts",
    "mission:e2e:matrix": "tsx scripts/mission-tool-use-e2e.ts --matrix",
    "mission:e2e:natural:core": "tsx scripts/mission-tool-use-e2e.ts --natural-matrix --natural-matrix-scenarios natural-comparison-research,natural-provider-search-pricing,natural-browser-dynamic-page,natural-followup-continuation,natural-approval-dry-run-action,natural-long-delegation,natural-asiawalk-multi-agent,natural-timeout-followup-continuation,natural-memory-recall",
    "mission:e2e:natural:browser-focused": "tsx scripts/mission-tool-use-e2e.ts --natural-matrix --natural-matrix-scenarios natural-browser-external-page-review,natural-browser-complex-page-review",
    "mission:e2e:natural:browser-reliability": "tsx scripts/mission-tool-use-e2e.ts --natural-matrix --natural-matrix-scenarios natural-browser-followup-continuation,natural-browser-restart-continuation,natural-browser-cold-recreation-continuation,natural-browser-profile-lock-recovery,natural-browser-unavailable-closeout,natural-browser-cdp-timeout-closeout,natural-browser-detached-target-closeout,natural-browser-attach-failed-closeout",
    "mission:e2e:natural": "tsx scripts/mission-tool-use-e2e.ts --natural-matrix",
    "mission:e2e:fixtures": "tsx scripts/natural-fixture-server.ts",
    "mission:e2e:thread-entry": "tsx scripts/mission-tool-use-e2e.ts --thread-entry",
    "acceptance:real": "tsx scripts/real-llm-acceptance.ts",
    "acceptance:ab:spec": "tsx scripts/real-llm-ab-spec-build.ts",
    "acceptance:ab:build": "tsx scripts/real-llm-ab-report-build.ts",
    "acceptance:ab:check": "tsx scripts/real-llm-ab-acceptance-check.ts",
    "ledger:check": "tsx scripts/agent-workbench-ledger-check.ts",
    "parity:policy-trace": "tsx scripts/engine-policy-trace-characterization.ts",
    "parity:policy-trace:write": "tsx scripts/engine-policy-trace-characterization.ts --write",
    "replay:run-trace": "tsx scripts/run-trace-replay.ts",
    "test:runtime-chaos": "tsx --test scripts/runtime-chaos-e2e.test.ts",
    "control-center:smoke": "tsx scripts/control-center-ui-smoke.ts",
    "pack:cli": "npm pack --workspace @turnkeyai/cli --dry-run",
    "install:local-cli": "npm link --workspace @turnkeyai/cli",
    "release:verify": "tsx scripts/release-readiness.ts",
    "phase1:baseline": "tsx scripts/phase1-readiness-baseline.ts",
    "soak:long": "tsx scripts/validation-soak-series.ts",
    "soak:ci": "tsx scripts/validation-soak-series.ts --cycles 10 --selectors soak,realworld,acceptance",
    "test": "node scripts/require-node.mjs && tsx --test packages/**/*.test.ts scripts/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "app": "tsx packages/cli/src/cli.ts app",
    "app:install-launcher": "tsx packages/cli/src/cli.ts app install-launcher",
    "doctor": "tsx packages/cli/src/cli.ts doctor",
    "daemon:start": "tsx packages/cli/src/cli.ts daemon start",
    "daemon:status": "tsx packages/cli/src/cli.ts daemon status",
    "daemon:stop": "tsx packages/cli/src/cli.ts daemon stop",
    "daemon": "tsx packages/app-gateway/src/daemon.ts",
    "tui": "tsx packages/cli/src/cli.ts tui"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
