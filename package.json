{
  "name": "turnkeyai",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @turnkeyai/cli && npm run build --workspace @turnkeyai/browser-relay-peer",
    "build:relay-extension": "npm run build --workspace @turnkeyai/browser-relay-peer",
    "verify:relay-extension": "tsx packages/browser-relay-peer/scripts/verify-extension-dist.ts",
    "relay:install-smoke": "tsx scripts/relay-extension-install-smoke.ts",
    "cdp:launch": "tsx scripts/launch-cdp-chrome.ts",
    "cdp:wait": "tsx scripts/wait-for-cdp-endpoint.ts",
    "cdp:smoke": "tsx scripts/direct-cdp-smoke.ts",
    "relay:launch": "tsx scripts/launch-relay-chrome.ts",
    "relay:wait": "tsx scripts/wait-for-relay-peer.ts",
    "relay:smoke": "tsx scripts/relay-smoke.ts",
    "transport:soak": "tsx scripts/browser-transport-soak.ts",
    "pack:cli": "npm pack --workspace @turnkeyai/cli --dry-run",
    "release:verify": "tsx scripts/release-readiness.ts",
    "phase1:baseline": "tsx scripts/phase1-readiness-baseline.ts",
    "soak:long": "tsx scripts/validation-soak-series.ts",
    "soak:ci": "tsx scripts/validation-soak-series.ts --cycles 10 --selectors soak,realworld,acceptance",
    "test": "tsx --test packages/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "daemon": "tsx packages/app-gateway/src/daemon.ts",
    "tui": "tsx packages/tui/src/tui.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
